APP_NAME=茶饮咖啡品牌投资与加盟风险智能分析系统
APP_ENV=development
DATABASE_URL=sqlite:///./tea_coffee_risk.db
# MySQL 示例：先在本机 MySQL 创建数据库 tea_coffee_brand_intel，再把下一行复制到 .env 并改密码。
# DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/tea_coffee_brand_intel?charset=utf8mb4

DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONER_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=60

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:8000/api
